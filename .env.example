# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in what you have. EVERY key is optional:
# a source with no key simply disables itself and the run continues without it.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (storage) ───────────────────────────────────────────────────────
# Without these, tools still return live results but nothing is persisted/cached.
SUPABASE_URL=
SUPABASE_KEY=                 # service_role key (server-side) recommended

# ── Behavior ─────────────────────────────────────────────────────────────────
FRESHNESS_HOURS=24            # serve cached rows instead of re-scraping within this window
HTTP_MAX_CONCURRENCY=8        # global cap on simultaneous outbound requests
HTTP_TIMEOUT_SECONDS=20
USER_AGENT=scraper-mcp/0.1 (+https://github.com/; research bot; contact=carlosglzg02@gmail.com)
# Optional comma-lists to force-enable/disable sources by name, e.g. DISABLED_SOURCES=trends_google
ENABLED_SOURCES=
DISABLED_SOURCES=

# ── Events ───────────────────────────────────────────────────────────────────
TICKETMASTER_API_KEY=         # free: https://developer.ticketmaster.com  (Discovery API)

# ── Web research / search ────────────────────────────────────────────────────
# DuckDuckGo needs no key. These improve quality when present (both have free tiers).
TAVILY_API_KEY=               # free ~1k/mo: https://tavily.com
BRAVE_API_KEY=                # free ~2k/mo: https://brave.com/search/api

# ── Trends / content ideas ───────────────────────────────────────────────────
REDDIT_CLIENT_ID=             # free: https://www.reddit.com/prefs/apps (type: script)
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=scraper-mcp/0.1 by u/yourname
YOUTUBE_API_KEY=              # free quota: Google Cloud Console -> YouTube Data API v3
# Hacker News + Google Trends need no keys.

# ── Meta official APIs (OWN-ACCOUNT scope only) ──────────────────────────────
# Requires a Meta Developer app + linked Business/Creator account. See README.
META_APP_ID=
META_APP_SECRET=
IG_ACCESS_TOKEN=              # long-lived user token with instagram_basic + pages perms
IG_BUSINESS_ACCOUNT_ID=       # your IG Business/Creator account id
THREADS_ACCESS_TOKEN=         # long-lived Threads token
THREADS_USER_ID=              # your Threads user id
